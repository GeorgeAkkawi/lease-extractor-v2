# Copy to .env.local and fill in. CRA exposes only REACT_APP_* vars to the browser.
# These two are safe for the browser (anon key is RLS-protected).
REACT_APP_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-side only — set as Supabase Edge Function secrets, NEVER as REACT_APP_*
# (anything REACT_APP_* is bundled into the browser). These live only on the server:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...      # AI extraction / Q&A
#   supabase secrets set RESEND_API_KEY=...                # reminder emails (optional)
#   supabase secrets set REMINDER_FROM_EMAIL=reminders@yourdomain.com
#   supabase secrets set CRON_SECRET=<long-random-string>  # authorizes the send-reminders cron call
#   supabase secrets set ALLOWED_ORIGIN=https://your-app-domain  # CORS lockdown for Edge Functions
#
# The Supabase SERVICE_ROLE key is also server-only. It is injected into Edge
# Functions automatically as SUPABASE_SERVICE_ROLE_KEY — never put it in .env.local
# and never expose it to the browser.
